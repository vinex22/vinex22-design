    "pen_names": ["pen name 1", "pen name 2"],
    "english_name": "English Name",
    "title": "your title / one-line introduction",
    "bio_short": "50-100 word bio",
    "bio_long": "200-300 word detailed bio",
    "avatar_url": "avatar URL",
    "source": "data source note"
  },

  "contact": {
    "email": "your@email.com",
    "handle": "your handle on chat platforms",
    "source": "data source note"
  },

  "social_media": {
